# Copy to ops/stream-paths.env and edit. That copy is gitignored —
# paths and hostnames are machine-local config, not framework.

# ── MacBook (capture) ────────────────────────────────────────
# Spool: recordings land here, ship to the mini, then get deleted locally.
STREAM_LOCAL="$HOME/Stream"

# Where recordings appear before ingest. Point every recording app here
# (QuickTime save location, screen-recording location, dictation app's
# audio export, etc.). Add as many as needed.
CAPTURE_DIRS=(
  "$HOME/Recordings"
  "$HOME/Desktop/Screenshots"
)

# ── Mac mini (canonical + compute) ───────────────────────────
MINI_USER="you"
MINI_HOST="mini.local"                     # or a fixed IP once you're on ethernet
STREAM_CANONICAL="/Users/you/Stream" # path ON THE MINI
REPO_DIR="$HOME/life-os"                   # repo location (used on the mini for derived/)

# ── Whisper (open-source, local) ─────────────────────────────
# mlx-whisper is the fast choice on Apple Silicon: pip install mlx-whisper
# Alternatives: openai-whisper CLI ("whisper"), or a whisper.cpp wrapper.
# Flags in transcribe-watch.sh follow the standard whisper CLI shape —
# adjust there if your install differs.
WHISPER_CMD="mlx_whisper"
WHISPER_MODEL="mlx-community/whisper-large-v3-turbo"

# ── Performance gates (see ops/lib/gate.sh) ──────────────────
# Heavy jobs (sync, transcribe, backup) defer to a later launchd tick
# whenever the machine is busy. Defaults work everywhere; override here.
# PERF_GATE_APPS="OBS"        # processes that block heavy work; "" disables
# PERF_IDLE_SECS=300          # user must be idle this long; 0 disables
# PERF_GATE_ON_BATTERY=1      # defer heavy work on battery
# PERF_GATE_DISPLAY=0         # also defer during calls/media (aggressive)
# SYNC_BWLIMIT=8192           # sync upload cap, KiB/s; "" uncaps

# ── QNAP NAS (backup, ethernet to mini) ──────────────────────
NAS_BACKUP_DIR="/Volumes/QNAP/stream-backup"   # mounted SMB path ON THE MINI

# ── Optional: pull derived/ back on every sync ───────────────
# Repo path ON THE MINI. When set, sync-to-mini.sh mirrors the mini's
# derived/ (transcripts, summaries) back to this machine's repo — useful
# when derived/ is not git-tracked. Leave unset to sync derived/ via git.
# MINI_REPO_DIR="/Users/you/life-os"
