# The stream lives OUTSIDE this repo entirely (see STREAM.md).
# If raw stream files ever show up in here, something is wrong —
# this pattern is a tripwire, not an invitation.
stream/

# ── Obsidian ─────────────────────────────────────────────────
# Track shared vault config if you want consistent settings
# across machines; never track per-machine workspace state.
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json

# ── Machine-local pipeline config ────────────────────────────
ops/stream-paths.env

# ── Secrets ──────────────────────────────────────────────────
# Real values live in self-hosted Infisical (infra/secrets/runbook.md).
# .env files never get committed; .env.example placeholders do.
# infra/secrets/.env is the Infisical bootstrap secret — committing it
# would be catastrophic.
.env
.env.*
!.env.example

# ── macOS noise ──────────────────────────────────────────────
.DS_Store
