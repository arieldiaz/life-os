# Infisical bootstrap config. Copy to .env (gitignored) and fill in.
# This .env is the ONE secret that cannot live in Infisical itself.
# Losing ENCRYPTION_KEY makes every database backup unrecoverable —
# keep an off-machine copy (see runbook.md § Backups).

# openssl rand -hex 16
ENCRYPTION_KEY=

# openssl rand -base64 32
AUTH_SECRET=

# Public URL the instance is served at (behind your reverse proxy)
SITE_URL=https://secrets.your-domain.com

# Postgres (compose-internal only; DB_CONNECTION_URI is assembled in docker-compose.yml)
POSTGRES_USER=infisical
POSTGRES_PASSWORD=
POSTGRES_DB=infisical

# Single-user instance: no invites needed day one, so SMTP stays off.
# Uncomment and fill if email invites/alerts are ever wanted.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_FROM_ADDRESS=
# SMTP_FROM_NAME=Infisical
# SMTP_USERNAME=
# SMTP_PASSWORD=

TELEMETRY_ENABLED=false
