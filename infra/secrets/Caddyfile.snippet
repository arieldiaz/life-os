# Append to your Caddyfile. Assumes a global ACME DNS block for wildcard/
# internal certs, e.g. { acme_dns cloudflare {env.CF_API_TOKEN} } — any
# dns.providers.* module works. The host stays tailnet/LAN-only via DNS
# pointing at a private IP; Infisical never needs public exposure.

secrets.your-domain.com {
	reverse_proxy localhost:8090 {
		header_up Host {upstream_hostport}
	}
}
